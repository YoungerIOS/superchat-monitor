{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XChat Monitor",
  "version": "0.1.0",
  "identifier": "com.superchat.monitor.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "XChat Monitor",
        "width": 760,
        "height": 540,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": [
      "bundled-runtime/monitor_tip.py",
      "bundled-runtime/monitor_ctl.sh",
      "bundled-runtime/requirements.txt",
      "bundled-python"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
